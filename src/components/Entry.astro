---
import { marked } from 'marked';
import type { Entry as EntryT } from '../lib/data.ts';
import { contributorDisplay, isRtl, bcp47, languages } from '../lib/data.ts';

export interface Props {
  entry: EntryT;
}

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;

const langCodes = Array.from(new Set(entry.forms.map((f) => f.lang)));
const commentHtml = entry.comment ? marked.parse(entry.comment, { async: false }) as string : null;
const etymologyHtml = (s: string) => marked.parseInline(s, { async: false }) as string;
const hasMeta = Boolean(entry.added || entry.contributor);
---
<article
  class="entry"
  data-id={entry.id}
  data-langs={langCodes.join(',')}
  data-contributor={entry.contributor ?? ''}
>
  <a class="entry-anchor" href={`${base}eintrag/${entry.id}/`} aria-label={`Eintrag ${entry.id}`}>※</a>
  <div class="entry-content">
    {hasMeta && (
      <div class="entry-meta">
        {entry.added && <time datetime={entry.added}>{entry.added}</time>}
        {entry.added && entry.contributor && <span>·</span>}
        {entry.contributor && (
          <a href={`${base}beitrager/${entry.contributor}/`}>{contributorDisplay(entry.contributor)}</a>
        )}
      </div>
    )}

    <ul class="forms">
      {entry.forms.map((f) => (
        <li class="form">
          <div class="lang-tag">
            <a href={`${base}sprache/${f.lang}/`}>{languages[f.lang]?.name ?? f.lang}</a>
            {f.dialect && <span class="dialect">{f.dialect}</span>}
          </div>
          <div class="form-body">
            {f.script && (
              <span class="script" lang={bcp47(f.lang)} dir={isRtl(f.lang) ? 'rtl' : 'ltr'}>{f.script}</span>
            )}
            {f.translit && <span class="translit">{f.translit}</span>}
            {f.gloss && <span class="gloss">{f.gloss}</span>}
            {f.etymology && <span class="etymology" set:html={etymologyHtml(f.etymology)} />}
          </div>
        </li>
      ))}
    </ul>

    {commentHtml && <div class="comment" set:html={commentHtml} />}

    {entry.sources && entry.sources.length > 0 && (
      <div class="sources">
        <ul>
          {entry.sources.map((s) => {
            const isUrl = s.startsWith('http://') || s.startsWith('https://');
            return <li>{isUrl ? <a href={s}>{s}</a> : s}</li>;
          })}
        </ul>
      </div>
    )}
  </div>
</article>
