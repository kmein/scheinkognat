---
import Base from '../../layouts/Base.astro';
import Entry from '../../components/Entry.astro';
import { entries, contributors, entriesByContributor, contributorDisplay } from '../../lib/data.ts';

export function getStaticPaths() {
  const byContrib = entriesByContributor();
  return [...byContrib.entries()].map(([id, list]) => ({
    params: { id },
    props: { id, entries: list },
  }));
}

const { id, entries: list } = Astro.props as { id: string; entries: typeof entries };
const base = import.meta.env.BASE_URL;
const c = contributors[id];
---
<Base title={`Beiträger: ${contributorDisplay(id)}`}>
  <div class="subnav">
    <a href={base}>← Übersicht</a>
  </div>
  <span class="eyebrow">Beiträger:in</span>
  <h1>{contributorDisplay(id)}</h1>
  <p class="index-summary">
    {list.length} {list.length === 1 ? 'Eintrag' : 'Einträge'}{c?.url && <>, <a href={c.url}>{c.url}</a></>}{c?.github && <>, <a href={`https://github.com/${c.github}`}>@{c.github}</a></>}.
  </p>

  <div>
    {list.map((e) => <Entry entry={e} />)}
  </div>
</Base>
