---
import Base from '../layouts/Base.astro';
import Entry from '../components/Entry.astro';
import { entries, languages, contributors, languageFrequencies, entriesByContributor } from '../lib/data.ts';

const langFreq = languageFrequencies().map((l) => ({
  code: l.code,
  name: languages[l.code]?.name ?? l.code,
  count: l.count,
}));

const topLangs = langFreq.slice(0, 30);

const contributorsWithEntries = [...entriesByContributor().keys()]
  .map((id) => ({ id, name: contributors[id]?.name ?? id }))
  .sort((a, b) => a.name.localeCompare(b.name, 'de'));
---
<Base description="Linguistische Koinzidenzen — sammelt zufällige Wortähnlichkeiten zwischen Sprachen.">
  <p class="index-summary">
    {entries.length} Einträge, {langFreq.length} Sprachen.
    Klick auf eine Sprache filtert; mehrere Klicks zeigen nur Einträge, die <em>alle</em> ausgewählten Sprachen enthalten.
  </p>

  <blockquote>
    <p>
      „wie mannigfach die zufällige Ähnlichkeit im sprachlichen Leben waltet …“
    </p>
    <p><em>— Johannes Friedrich, <a href="https://doi.org/10.1515/9783110243017.156">1952</a></em></p>
  </blockquote>


  <div class="filter-bar" id="filter-bar">
    <input id="q" type="search" aria-label="Volltextsuche" placeholder="In Einträgen suchen…" />

    <div>
      <h3>Sprachen <span style="font-weight:400;color:var(--fg-quiet);">(alle ausgewählten müssen vorkommen)</span></h3>
      <div class="chips" id="lang-chips">
        {topLangs.map((l) => (
          <button type="button" class="chip" data-lang={l.code} aria-pressed="false">
            {l.name}<span class="count">{l.count}</span>
          </button>
        ))}
      </div>
    </div>

    <div>
      <h3>Beiträger</h3>
      <select id="contrib" aria-label="Beiträger filter">
        <option value="">— alle —</option>
        {contributorsWithEntries.map((c) => (
          <option value={c.id}>{c.name}</option>
        ))}
      </select>
    </div>

    <div class="count-line">
      <span id="result-count">{entries.length}</span> Einträge sichtbar
      <button class="reset" id="reset" type="button" hidden>Filter zurücksetzen</button>
    </div>
  </div>

  <div id="entry-list">
    {entries.map((e) => <Entry entry={e} />)}
  </div>
</Base>

<script>
  (() => {
    const norm = (s: string) => s.toLowerCase().normalize('NFKD').replace(/[̀-ͯ]/g, '');

    const $q     = document.getElementById('q') as HTMLInputElement;
    const $contrib = document.getElementById('contrib') as HTMLSelectElement;
    const $reset = document.getElementById('reset') as HTMLButtonElement;
    const $count = document.getElementById('result-count') as HTMLElement;
    const $chips = document.querySelectorAll<HTMLButtonElement>('#lang-chips .chip');
    const $cards = document.querySelectorAll<HTMLElement>('#entry-list article.entry');

    let langs: string[] = [];

    function readUrl() {
      const p = new URLSearchParams(window.location.search);
      langs = (p.get('sprache') ?? '').split(',').filter(Boolean);
      $contrib.value = p.get('beitrager') ?? '';
      $q.value = p.get('q') ?? '';
    }

    function writeUrl() {
      const p = new URLSearchParams();
      if (langs.length) p.set('sprache', langs.join(','));
      if ($contrib.value) p.set('beitrager', $contrib.value);
      if ($q.value) p.set('q', $q.value);
      const qs = p.toString();
      history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
    }

    function apply() {
      const qLow = norm($q.value.trim());
      const contributor = $contrib.value;
      let visible = 0;
      for (const card of $cards) {
        const cardLangs = (card.dataset.langs ?? '').split(',');
        let show = true;
        if (langs.length) show = langs.every((l) => cardLangs.includes(l));
        if (show && contributor) show = (card.dataset.contributor ?? '') === contributor;
        if (show && qLow) show = norm(card.textContent ?? '').includes(qLow);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      $count.textContent = String(visible);

      // chip state + reset visibility
      for (const chip of $chips) {
        const active = langs.includes(chip.dataset.lang ?? '');
        chip.setAttribute('aria-pressed', active ? 'true' : 'false');
      }
      $reset.hidden = !($q.value || $contrib.value || langs.length);

      writeUrl();
    }

    $q.addEventListener('input', apply);
    $contrib.addEventListener('change', apply);
    $reset.addEventListener('click', () => {
      langs = []; $q.value = ''; $contrib.value = ''; apply();
    });
    for (const chip of $chips) {
      chip.addEventListener('click', () => {
        const code = chip.dataset.lang ?? '';
        const i = langs.indexOf(code);
        if (i >= 0) langs.splice(i, 1); else langs.push(code);
        apply();
      });
    }
    window.addEventListener('popstate', () => { readUrl(); apply(); });

    readUrl();
    apply();
  })();
</script>
